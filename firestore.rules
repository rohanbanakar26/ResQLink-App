rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PROFILES ──
    match /profiles/{userId} {
      // Anyone authenticated can read profiles (needed for displaying names/roles of teammates or citizens)
      allow read: if request.auth != null;
      // Users can only update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── NGOs ──
    match /ngos/{ngoId} {
      // Publicly readable so the system can allocate tasks and users can see NGO info
      allow read: if true;
      // Only the assigned NGO user can update their NGO document (or authenticated users creating one)
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // ── VOLUNTEERS ──
    match /volunteers/{volId} {
      // Public read for coordination
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // The volunteer themselves can always update their own doc.
      // Any authenticated user can also update a volunteer doc so that
      // the NGO auto-assignment engine (client-side on Spark plan) can
      // set available=false / current_task_id when dispatching.
      // When upgraded to Blaze, lock this back down to self-only and use
      // Cloud Functions (Admin SDK) for the assignment writes.
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // ── EMERGENCY REQUESTS ──
    match /emergency_requests/{requestId} {
      // Allow read for all authenticated users to allow the application's global feed of "Nearby Missions" to function.
      // (Restricting reads per document requires complex composite queries and indexes in the client SDK.)
      allow read: if request.auth != null;
      
      // CREATE: Only the user claiming to be the creator can create it
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      
      // UPDATE: Citizen (owner), the primary NGO, any assigned volunteer,
      // or any authenticated user when the request is still unclaimed (no NGO
      // yet) so the escalation engine and NGO acceptance can write freely.
      allow update: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        resource.data.ngo_id == request.auth.uid ||
        (resource.data.assigned_volunteer_ids != null &&
          request.auth.uid in resource.data.assigned_volunteer_ids) ||
        !('ngo_id' in resource.data) ||
        resource.data.ngo_id == null ||
        resource.data.ngo_id == ""
      );
      
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;

      // ── Subcollections for assignments (Per-volunteer state) ──
      match /assignments/{assignmentId} {
        allow read: if request.auth != null;
        // The volunteer themselves can update their own assignment doc (acknowledge).
        // Any authenticated user can CREATE or DELETE an assignment so the
        // auto-assignment engine and timeout engine can write on Spark plan.
        allow create, delete: if request.auth != null;
        allow update: if request.auth != null;
      }
    }

    // ── REPORTS (Misuse) ──
    match /request_reports/{reportId} {
      // No one can read reports except admins via Firebase Console
      allow read: if false; 
      // Anyone authenticated can create a report, but they must identify as themselves
      allow create: if request.auth != null && request.resource.data.reporter_id == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
