rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PUBLIC: NGOs are readable by anyone (needed for volunteer registration form) ──
    match /ngos/{ngoId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // ── ALL OTHER COLLECTIONS: Any authenticated user can read and write ──
    // This ensures the assignment engine, escalation timers, notification
    // system, volunteer tracking, and all real-time listeners work correctly
    // without permission-denied errors during auth state transitions.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
